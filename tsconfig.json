{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "lib": ["ES2022"],
    "outDir": "out",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "moduleResolution": "Node",
    "skipLibCheck": true,
    "sourceMap": true,
    "types": ["node", "vscode"],
    "ignoreDeprecations": "6.0"
  },
  "include": ["src/**/*.ts"]
}
